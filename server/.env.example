# --- Demo (Día 1) ---
PORT=3000
API_KEY=dev-api-key
HMAC_SECRET=dev-hmac-secret
CACHE_TTL_HOURS=24
DEDUP_WINDOW_SEC=60

# --- SUNARP real (Día 2) ---
# Mock por defecto. Para activar el scraper real: USE_MOCK_SUNARP=false  (+ TWOCAPTCHA_KEY)
USE_MOCK_SUNARP=true
# TWOCAPTCHA_KEY=tu_clave_de_2captcha
# SUNARP_URL=https://www.sunarp.gob.pe/consulta-vehicular   # CALIBRAR contra el sitio real
# HEADLESS=true            # false para ver el navegador (debug)
# NAV_TIMEOUT_MS=30000
# SUNARP_CAPTCHA_ATTEMPTS=3

# --- SOAT real (Día 3) ---
USE_MOCK_SOAT=true
# SOAT_URL=https://consultasoat.apeseg.org.pe          # CALIBRAR
# SOAT_CAPTCHA_ATTEMPTS=3

# --- MTC / revisión técnica real (Día 3) ---
USE_MOCK_MTC=true
# MTC_URL=https://rec.mtc.gob.pe/Citv/ConsultaCitv      # CALIBRAR
# MTC_CAPTCHA_ATTEMPTS=3

# --- Cache (Día 3) ---
# CACHE_TTL_HOURS=24            # resultados completos
# CACHE_PARTIAL_TTL_HOURS=1     # resultados parciales (alguna fuente falló): reintenta antes

# --- PDF + Webhook (Día 4) ---
# PDF_ENABLED=true                          # false = solo HTML (sin Chromium para PDF)
# PUBLIC_BASE_URL=http://localhost:3000     # base para las URLs absolutas del webhook
# WEBHOOK_URL=http://localhost:4000/webhook # destino global si la detección no trae callback_url

# --- Hardening + anonimización (Día 5) ---
# RATE_MAX_CONCURRENCY=2      # máx. consultas simultáneas a una MISMA fuente
# RATE_MIN_INTERVAL_MS=1500   # intervalo mínimo entre consultas a una fuente (recomendado en real)
# ANONYMIZE_OWNER=true        # enmascara el propietario en el reporte (figuras del paper)

# --- Producción (más adelante) ---
# Si REDIS_URL está seteado, se usaría BullMQ en lugar de la cola en memoria.
# REDIS_URL=redis://localhost:6379
